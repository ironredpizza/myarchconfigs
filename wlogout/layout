{
    "label" : "shutdown",
    "action" : "systemctl poweroff",
    "text" : "Shutdown",
    "keybind" : "s"
}
{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "text" : "Reboot",
    "keybind" : "r"
}
{
    "label" : "logout",
    "action" : "loginctl kill-session $XDG_SESSION_ID",
    "text" : "Logout",
    "keybind" : "e"
}
{
    "label" : "hibernate",
    "action" : "bash ~/.config/hypr/scripts/hyprlock-launch.sh && systemctl hibernate",
    "text" : "Hibernate",
    "keybind" : "h"
}
{
    "label" : "lock",
    "action" : "pkill wlogout & sleep 0.2 && bash ~/.config/hypr/scripts/hyprlock-launch.sh",
    "text" : "Lock",
    "keybind" : "l"
}
